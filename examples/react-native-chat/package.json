  "dependencies": {
    "@openhorizon/sapient": "file:../../sdks/typescript",
    "@openhorizon/sapient-react-native": "file:../../sdks/react-native",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-file-system": "~18.0.12",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.5"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
